# Supabase (auth + realtime + storage signed URLs).
# Без этих значений auth/realtime/signed-URL работают в degraded-режиме (warning в UI).
# ВАЖНО: ровно тот же проект Supabase, что у бэкенда (backend/.env) — иначе
# JWT фронта не пройдёт RLS бэка, а realtime/signed-URL будут смотреть в чужую БД.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# База API бэкенда (apps/api). Пусто = same-origin (/api/...).
# Кросс-домен (напр. http://localhost:3001): на бэке выставь APP_URL = origin фронта,
# иначе CORS заблокирует (backend/apps/api/middleware.ts → Access-Control-Allow-Origin).
NEXT_PUBLIC_API_BASE=
